{
  "name": "kmddns",
  "version": "1.0.0",
  "description": "TypeScript client SDK for KmDDNS — keep your dynamic DNS record updated automatically.",
  "keywords": [
    "ddns",
    "dynamic-dns",
    "cloudflare",
    "kmddns"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0"
  }
}
